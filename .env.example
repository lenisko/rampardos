PREVIEW_LATITUDE=52.2481508     # Preview center latitude
PREVIEW_LONGITUDE=-21.0122546   # Preview center longitude
ADMIN_USERNAME=psyduck          # Admin username
ADMIN_PASSWORD=dupa.8!          # Admin password
PUID=0                          # User ID (0 = root)
PGID=0                          # Group ID (0 = root)
# MARKER_IMAGE_CACHE_SIZE=2000   # Max resized marker images in memory (default: 2000)
# LOCAL_STYLES_USE_VIEWPORT=true # Render local styles via native viewport (default: true). Set false to tile-stitch integer zooms.

EXPERIMENTAL_G_SAT=false         # Enable Google Satellite external style (default: true)
# PNG_COMPRESSION_LEVEL=best     # PNG compression: fast, best, default, none (default: best)
# Other output types than png no ring ring yet

# Cache drop settings - force remove files older than X minutes regardless of access (default: 129600 = 90 days)
# Useful if we want to enforce fetching a new version of tiles/markers etc...
# TILE_CACHE_DROP_AFTER_MINUTES=129600
# STATIC_CACHE_DROP_AFTER_MINUTES=129600
# STATIC_MULTI_CACHE_DROP_AFTER_MINUTES=129600
# MARKER_CACHE_DROP_AFTER_MINUTES=129600
# REGENERATABLE_CACHE_DROP_AFTER_MINUTES=129600
